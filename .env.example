# Copy to .env (gitignored) and fill in real values.
# `docker compose up` reads .env automatically.

# Default provider for the bundled stack. UI can switch at runtime via AI Settings.
SPECS_AGENT_AI_PROVIDER=anthropic

# Anthropic — paste your key here for the local stack.
SPECS_AGENT_AI_ANTHROPIC_API_KEY=
SPECS_AGENT_AI_ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI
SPECS_AGENT_AI_OPENAI_API_KEY=
SPECS_AGENT_AI_OPENAI_MODEL=gpt-4o-mini
SPECS_AGENT_AI_OPENAI_BASE_URL=

# OpenAI-compatible (Ollama / vLLM / Docker Model Runner). Defaults route
# through Docker Model Runner on Mac with Metal GPU.
SPECS_AGENT_AI_HTTP_BASE_URL=http://model-runner.docker.internal/engines/v1
SPECS_AGENT_AI_HTTP_MODEL=hf.co/unsloth/gemma-4-E4B-it-GGUF:Q4_K_M
SPECS_AGENT_AI_HTTP_API_KEY=
